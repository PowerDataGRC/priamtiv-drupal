{# Contact form section #}
<section class="py-5 py-lg-6 bg-mint" id="contact">
  <div class="container-xl">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="mb-5 text-center">
          <span class="priam-eyebrow">Get in touch</span>
          <h2 class="priam-section-title mt-2">Talk to us before you sign up</h2>
          <p class="lead mt-3" style="max-width:60ch; margin-inline:auto; color: var(--priam-ink-700);">
            Have a question about PRIAM? Not sure if it's right for your business?
            We'll get back to you within one business day — no sales pressure.
          </p>
        </div>

        <div class="bg-white rounded-4 p-4 p-md-5 shadow-sm">
          {{ contact_form }}
        </div>

      </div>
    </div>
  </div>
</section>
