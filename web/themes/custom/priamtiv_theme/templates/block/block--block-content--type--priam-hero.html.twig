{# Hero / Jumbotron section #}
<section class="priam-hero bg-cream" id="hero">
  <div class="container-xl">
    <div class="row align-items-center g-5 py-lg-5">

      {# Copy column #}
      <div class="col-lg-6">
        <span class="badge rounded-pill px-3 py-2 mb-4 d-inline-flex align-items-center gap-2"
              style="background:rgba(15,110,86,0.10); color: var(--priam-teal-700); font-size: 0.8125rem; font-weight:500;">
          <span style="width:8px;height:8px;border-radius:999px;background:var(--priam-teal-500);display:inline-block;"></span>
          Built for small business owners, not GRC teams
        </span>

        <h1 class="priam-hero h1 mb-4">
          Risk visibility, <em>without</em> the overhead.
        </h1>

        <p class="lead mb-4" style="color: var(--priam-ink-700);">
          PRIAM is the simple platform for small businesses to track policies,
          assess risk, log incidents, and keep tabs on every asset — all in one place.
        </p>

        <div class="d-flex flex-wrap gap-3 mb-4">
          <a class="btn btn-primary btn-lg" href="https://powerdatainc.com/hello/">
            Start free trial →
          </a>
          <a class="btn btn-outline-secondary btn-lg" href="https://powerdatainc.com/hello/">
            Book a 20-min walkthrough
          </a>
        </div>

        <div class="d-flex gap-4 flex-wrap" style="font-size: 0.875rem; color: var(--priam-ink-500);">
          <span>✓ Setup in 5 min</span>
          <span>✓ No credit card</span>
          <span>✓ Cancel anytime</span>
        </div>
      </div>

      {# Visual column #}
      <div class="col-lg-6 position-relative">
        <div class="priam-hero-img rounded-3 overflow-hidden"
             style="background: var(--priam-navy-900); aspect-ratio: 16/10; display:flex; align-items:center; justify-content:center;">
          <span style="color:rgba(244,241,234,0.2); font-family:'Fraunces',serif; font-size:2rem;">
            [Dashboard screenshot]
          </span>
        </div>

        {# Float card TL #}
        <div class="position-absolute top-0 start-0 translate-middle-y ms-4 mt-4 bg-white rounded-3 shadow px-3 py-2 d-none d-lg-flex align-items-center gap-2"
             style="margin-top: 3rem !important; font-size: 0.8rem;">
          <span style="width:8px;height:8px;border-radius:999px;background:var(--priam-teal-500);"></span>
          <div>
            <div style="font-size:0.7rem;color:var(--priam-ink-300);">Risk score</div>
            <div style="font-weight:600;">49 <span style="color:var(--bs-secondary);font-size:0.75rem;">Medium</span></div>
          </div>
        </div>

        {# Float card BR #}
        <div class="position-absolute bottom-0 end-0 mb-4 me-4 bg-white rounded-3 shadow px-3 py-2 d-none d-lg-flex align-items-center gap-2"
             style="font-size: 0.8rem;">
          <span style="width:8px;height:8px;border-radius:999px;background:var(--bs-secondary);"></span>
          <div>
            <div style="font-size:0.7rem;color:var(--priam-ink-300);">Incidents this week</div>
            <div style="font-weight:600;">3 open <span style="color:var(--priam-ink-300);font-size:0.75rem;">2 resolved</span></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
